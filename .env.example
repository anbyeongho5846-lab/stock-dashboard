# KIS (한국투자증권) Open API 설정
# 1. https://apiportal.koreainvestment.com 에서 앱 등록
# 2. 이 파일을 .env 로 복사 후 실제 값 입력
# 3. .env 는 절대 git에 커밋하지 마세요

KIS_APP_KEY=여기에_앱키_입력
KIS_APP_SECRET=여기에_시크릿_입력

# 계좌번호: 앞 8자리-뒤 2자리 형식 (예: 12345678-01)
KIS_ACCOUNT=12345678-01

# 모의투자=paper / 실전=real  (처음엔 반드시 paper!)
KIS_MODE=paper
